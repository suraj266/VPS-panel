# Production environment for docker-compose.prod.yml
# Copy to .env on your VPS and fill in values.
#
#   cp .env.prod.example .env
#   # Generate secrets:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"

# Image tag — built locally or pulled from your registry
PANEL_IMAGE=vps-panel:latest

# Where the panel is reachable from a browser (used for CORS allow-list).
# Set to your real hostname once you point DNS.
PANEL_ORIGIN=https://panel.example.com

# Postgres
POSTGRES_USER=panel
POSTGRES_PASSWORD=replace-me-strong-password
POSTGRES_DB=panel

# Panel
SESSION_SECRET=replace-me-48-byte-base64-string
PANEL_MASTER_KEY=replace-me-32-byte-base64-string

# Initial admin (created on first run if no users exist)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace-me-strong-password
