# ---------- API ----------
NODE_ENV=development
API_PORT=4000

DATABASE_URL=postgresql://panel:panel@localhost:5433/panel
REDIS_URL=redis://localhost:6379

# Long random string (>= 32 chars). Used to sign session cookies.
SESSION_SECRET=replace-me-with-a-long-random-string-min-32-chars

# 32-byte key (base64) used to encrypt env-var secrets at rest.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
PANEL_MASTER_KEY=replace-with-32-byte-base64-key

# Linux/Mac: /var/run/docker.sock (ignored on Windows; named pipe used automatically)
DOCKER_SOCKET=/var/run/docker.sock

# CORS — the web app origin
CORS_ORIGIN=http://localhost:3030

# Initial admin (created automatically on first run if no users exist)
ADMIN_EMAIL=admin@local
ADMIN_PASSWORD=changeme123
